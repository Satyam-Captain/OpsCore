{
  "id": "add_license_resource_ls",
  "name": "Add license resource (LS)",
  "description": "Request-scoped workflow for adding a license resource (License Scheduler path). You start with an ITSM request number only; deployment target cluster is selected later or manually.",
  "inputs": [
    {
      "id": "request_number",
      "label": "Request number",
      "type": "text"
    }
  ],
  "steps": [
    "request_check",
    "collect_inputs",
    "preview_db",
    "generate_config",
    "publish_request",
    "manual_followup"
  ],
  "request_blueprint": {
    "mode": "exclusive",
    "label": "LS license resource request",
    "description": "Single-request workspace: guided DB rows (license_servers, resources_REF) then LSB resources and LSF License Scheduler configs. Completion when required configs are published (see completion_strategy).",
    "completion_strategy": "all_required_configs_published"
  },
  "config_files": [
    {
      "id": "lsb.resources",
      "label": "LSB resources",
      "short_label": "lsb.resources",
      "order": 1,
      "depends_on_tables": [
        "license_servers",
        "resources_REF"
      ],
      "generation_supported": true,
      "diff_supported": true,
      "publish_supported": true,
      "required_for_finalization": true
    },
    {
      "id": "lsf.licensescheduler",
      "label": "LSF License Scheduler",
      "short_label": "lsf.licensescheduler",
      "order": 2,
      "depends_on_tables": [
        "license_servers",
        "resources_REF"
      ],
      "generation_supported": true,
      "diff_supported": true,
      "publish_supported": true,
      "required_for_finalization": true
    }
  ],
  "tables": {
    "license_servers": {
      "id": "license_servers",
      "label": "License servers",
      "table_name": "license_servers",
      "reuse_within_request": true,
      "prefill_mode": "sample_row",
      "defaults": {
        "ready4MIP": 0
      },
      "guided_group": "license_server",
      "field_hints": "Uses guided_inputs with group license_server"
    },
    "resources_REF": {
      "id": "resources_REF",
      "label": "Resources REF",
      "table_name": "resources_REF",
      "reuse_within_request": true,
      "prefill_mode": "sample_row",
      "defaults": {
        "active": 1,
        "useReason": 1,
        "res_type": "Numeric",
        "useLS": 1,
        "wlDistLS": 100
      },
      "guided_group": "resource_ref",
      "field_hints": "LS path: resource row includes License Scheduler-oriented defaults (useLS, wlDistLS)."
    }
  },
  "guided_inputs": [
    {
      "key": "application",
      "label": "Application",
      "group": "license_server",
      "table": "license_servers",
      "column": "application",
      "type": "text",
      "required": false,
      "placeholder": "e.g. hyperworks_v11",
      "help_mode": "unique_values",
      "help_table": "license_servers",
      "help_column": "application"
    },
    {
      "key": "site",
      "label": "Site",
      "group": "license_server",
      "table": "license_servers",
      "column": "site",
      "type": "text",
